# ALFA OS sandbox environment.
# Copy to .env.local when you want to run locally against sandbox.
# Never put production Supabase, Facturama, Resend, WhatsApp or Vercel values here.

# App URLs
NEXT_PUBLIC_APP_URL=http://localhost:3000
APP_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_PORTAL_URL=http://localhost:3000
PORTAL_URL=http://localhost:3000
PORTAL_HOST=localhost

# Supabase sandbox project
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-SANDBOX-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=YOUR_SANDBOX_PUBLISHABLE_OR_ANON_KEY
SUPABASE_URL=https://YOUR-SANDBOX-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR_SANDBOX_SERVICE_ROLE_KEY

# Facturama sandbox only
FACTURAMA_ENV=sandbox
FACTURAMA_ENABLE_PRODUCTION=false
FACTURAMA_USERNAME=YOUR_FACTURAMA_SANDBOX_USERNAME
FACTURAMA_PASSWORD=YOUR_FACTURAMA_SANDBOX_PASSWORD
FACTURAMA_EXPEDITION_PLACE=00000
FACTURAMA_SANDBOX_RECEIVER_RFC=EKU9003173C9
FACTURAMA_SANDBOX_RECEIVER_NAME=ESCUELA KEMPER URGATE
FACTURAMA_SANDBOX_RECEIVER_TAX_REGIME=601
FACTURAMA_SANDBOX_RECEIVER_ZIP_CODE=42501

# Payment complements sandbox behavior
PAYMENT_COMPLEMENTS_ENV=sandbox
PAYMENT_COMPLEMENTS_ENABLED=true
PAYMENT_COMPLEMENTS_STAMPING_ENABLED=false

# Email sandbox
RESEND_API_KEY=YOUR_RESEND_SANDBOX_OR_TEST_KEY
EMAIL_FROM=ALFA OS Sandbox <sandbox@example.com>
INVOICE_EMAIL_FROM=ALFA OS Sandbox <sandbox@example.com>
POSTSALE_CC_EMAILS=
DIRECTOR_EMAILS=

# WhatsApp sandbox/mock
WHATSAPP_PROVIDER=mock
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=

# Optional integrations
BANXICO_TOKEN=
ALFA_SUPPORT_EMAIL=sandbox-support@example.com
ALFA_REPRESENTATIVE_NAME=ALFA OS Sandbox
